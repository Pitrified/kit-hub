## LLM ##

# OpenAI API key (required for recipe parsing and transcription via llm-core)
OPENAI_API_KEY=sk-...  # pragma: allowlist secret

## WEBAPP ##

# Google OAuth (required)
GOOGLE_CLIENT_ID=aaa.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=some-secret-value  # pragma: allowlist secret

# Session security (required in production, auto-generated in dev)
SESSION_SECRET_KEY=some-secret-value  # pragma: allowlist secret
